# Copy this into your project's flake.nix (or merge with an existing flake).
#
# Prerequisites:
#   - sbt project with committed repo.nix lockfiles (run `sbtix-gen` in nix develop)
#   - buildSbtProgram expects a `stage` task (sbt-native-packager)
#
# Full runnable example: examples/flake-app/

{
  description = "sbt project built with sbtix (flake-native workflow)";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
    sbtix.url = "github:natural-transformation/sbtix/v1.0.3";
    sbtix.inputs.nixpkgs.follows = "nixpkgs";
  };

  outputs = { self, nixpkgs, sbtix, ... }:
    let
      systems = [
        "x86_64-linux"
        "aarch64-linux"
        "aarch64-darwin"
      ];
      forAllSystems = nixpkgs.lib.genAttrs systems;
    in {
      devShells = forAllSystems (system:
        let pkgs = import nixpkgs { inherit system; };
        in {
          default = pkgs.mkShell {
            packages = [ sbtix.packages.${system}.sbtix ];
          };
        });

      packages = forAllSystems (system:
        let
          pkgs = import nixpkgs { inherit system; };
          sbtixLib = pkgs.callPackage "${sbtix}/plugin/nix-exprs/sbtix.nix" {
            jdk = pkgs.jdk;
            jre = pkgs.jdk;
          };
        in {
          default = sbtixLib.buildSbtProgram {
            name = "my-app";
            src = pkgs.lib.cleanSource ./.;
            repo = [
              (import ./manual-repo.nix)
              (import ./repo.nix)
              (import ./project/repo.nix)
              # Omit the next line if project/project/repo.nix does not exist:
              (import ./project/project/repo.nix)
            ];
          };
        });
    };
}
