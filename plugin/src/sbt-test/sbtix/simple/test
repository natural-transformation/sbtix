# Test to verify the plugin works with the current Coursier-backed fetcher
> compile
> sbtixGenerate
$ exists repo.nix
$ exists project/repo.nix

# The application repository should contain the resolved build artifacts, but
# cached metadata for evicted modules is intentionally not part of its contract.
$ exec grep -q 'org/scala-lang/scala-library/2.13.18/scala-library-2.13.18.jar' repo.nix
$ exec grep -q 'org/scalatest/scalatest_2.13/3.2.20/scalatest_2.13-3.2.20.jar' repo.nix
$ exec grep -q 'io/github/java-diff-utils/java-diff-utils/4.16/java-diff-utils-4.16.jar' repo.nix
$ exec sh -c '! grep -q "io/github/java-diff-utils/java-diff-utils/4.12/java-diff-utils-4.12.jar" repo.nix'

# The project/plugin repository must retain its full deterministic fixture.
$ must-mirror project/repo.nix expected/project-repo.nix

# Generate the default.nix for building
> genComposition
$ exists default.nix

# Run nix-build to verify the whole build works with Coursier compatibility
$ exec rm -rf result
$ exec nix-build
$ exists result

# Verify the generated Nix contains the correct symlink strategy for Coursier compatibility
$ exec grep -q 'cat <<IVY_EOF > $ivyDir/ivys/ivy.xml' sbtix-generated.nix
$ exec grep -q 'ln -sf ivy.xml' sbtix-generated.nix

# Test the generated executable
$ exec result/bin/three

# Note: Full nix-build testing can be done manually in a Nix environment:
# $ exec rm -rf result
# $ exec nix-build
# $ exists result
